# ============================================
# WA-SENT : WhatsApp Report Automation
# Copy file ini menjadi .env lalu sesuaikan
# ============================================

APP_PORT=3100
NODE_ENV=production

WA_SESSION_PATH=./wa-sessions
WA_MAX_RETRY=3
WA_RETRY_DELAY=5000

WA_TARGET_PERSONAL=6281234567890@s.whatsapp.net
WA_TARGET_GROUP=120363xxxxx@g.us

DASHBOARD_URL=http://localhost:4200
SCREENSHOT_WIDTH=1920
SCREENSHOT_HEIGHT=1080
SCREENSHOT_TIMEOUT=30000
SCREENSHOT_PATH=./screenshots

CRON_SCHEDULE=0 * * * *

LOG_LEVEL=info
LOG_DIR=./logs
